---
import ProjectTimeline from '../components/ProjectTimeline.astro';
import { eras } from '../data/archive';
import BaseLayout from '../layouts/BaseLayout.astro';

// Reverse: most recent first so page loads in current Forest theme
const reversedEras = [...eras].reverse();
---

<BaseLayout>
  <article class='archive'>
    <header class='archive-header'>
      <h1>Archive</h1>
      <p class='archive-subtitle'>Still growing. Scroll down to travel back in time.</p>
    </header>

    <ProjectTimeline entries={reversedEras} />

    <footer class='archive-footer'>
      <p>Where it all started.</p>
    </footer>
  </article>
</BaseLayout>

<style>
  .archive-header {
    text-align: center;
    margin-bottom: 1em;
  }
  .archive-subtitle {
    color: var(--text-secondary);
    font-size: 1.1em;
    font-style: italic;
  }
  .archive-footer {
    text-align: center;
    padding: 2em 0;
    color: var(--text-secondary);
    font-style: italic;
  }
  :global(body) {
    transition: background-color 0.6s ease, color 0.6s ease;
  }
</style>

<script>
  import { initArchiveObserver } from '../scripts/archive-observer';
  document.addEventListener('astro:page-load', initArchiveObserver);
</script>
