---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

const recentPosts = (await getCollection('blog'))
  .filter((p) => p.data.pubDate)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout>
  <div class='hero'>
    <h1>Hi, I'm Ed Ezekiel</h1>
    <p class='tagline'>
      Senior Engineer at <a href='https://herodevs.com/' target='_blank'>HeroDevs</a>.
      Former attorney. Building product security tooling and AI-assisted automation.
    </p>
    <div class='hero-footprints'>
      <span class='hero-print'></span>
      <span class='hero-print'></span>
      <span class='hero-print'></span>
      <span class='hero-print'></span>
      <span class='hero-print'></span>
    </div>
  </div>

  <section class='recent-posts'>
    <h3>Recent Posts</h3>
    <ul>
      {
        recentPosts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <span class='post-title'>{post.data.title}</span>
              <span class='post-date'><FormattedDate date={post.data.pubDate} /></span>
              <span class='footprints'>
                <span class='fp'></span>
                <span class='fp'></span>
                <span class='fp'></span>
                <span class='fp'></span>
                <span class='fp'></span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class='projects'>
    <h3>Projects</h3>
    <div class='projects-grid'>
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class='speaking'>
    <h3>Speaking</h3>
    <ul>
      <li>
        <a
          href='https://www.meetup.com/angularcommunity/events/298226033/'
          target='_blank'>Angular Community Meetup</a
        >, January 23rd, 2024
      </li>
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 2.5em;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -60px;
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse at 80% 10%, rgba(196, 183, 130, 0.09) 0%, rgba(122, 154, 94, 0.03) 40%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }
  .hero-footprints {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-top: 1.5em;
  }
  .hero-print {
    width: 4px;
    height: 4px;
    background: var(--accent);
    border-radius: 50%;
    opacity: 0;
    animation: footprint-appear 0.4s ease forwards;
  }
  .hero-print:nth-child(1) { animation-delay: 0.6s; }
  .hero-print:nth-child(2) { animation-delay: 0.9s; width: 3px; height: 3px; }
  .hero-print:nth-child(3) { animation-delay: 1.2s; }
  .hero-print:nth-child(4) { animation-delay: 1.5s; width: 3px; height: 3px; }
  .hero-print:nth-child(5) { animation-delay: 1.8s; }
  @keyframes footprint-appear {
    to { opacity: 0.4; }
  }
  .hero h1 {
    margin-bottom: 0.3em;
  }
  .tagline {
    font-size: 1.15em;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.6;
  }
  .recent-posts ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }
  .recent-posts li {
    position: relative;
  }
  .recent-posts li a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1em;
    padding: 0.75em 1em;
    text-decoration: none;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  .recent-posts li a:hover {
    background-color: var(--bg-card);
    border-color: var(--border);
  }
  .recent-posts .footprints {
    position: absolute;
    right: 1em;
    bottom: 4px;
    display: flex;
    gap: 5px;
    align-items: center;
    pointer-events: none;
  }
  .recent-posts .fp {
    width: 4px;
    height: 4px;
    background: var(--accent);
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .recent-posts .fp:nth-child(2),
  .recent-posts .fp:nth-child(4) {
    width: 3px;
    height: 3px;
  }
  .recent-posts li a:hover .fp:nth-child(1) { opacity: 0.5; transition-delay: 0s; }
  .recent-posts li a:hover .fp:nth-child(2) { opacity: 0.5; transition-delay: 0.1s; }
  .recent-posts li a:hover .fp:nth-child(3) { opacity: 0.5; transition-delay: 0.2s; }
  .recent-posts li a:hover .fp:nth-child(4) { opacity: 0.5; transition-delay: 0.3s; }
  .recent-posts li a:hover .fp:nth-child(5) { opacity: 0.5; transition-delay: 0.4s; }
  .post-title {
    color: var(--text-primary);
    transition: color 0.2s ease;
  }
  .recent-posts li a:hover .post-title {
    color: var(--accent-warm);
  }
  .post-date {
    color: var(--text-secondary);
    font-size: 0.85em;
    white-space: nowrap;
  }
  section {
    margin-bottom: 2em;
  }
  h3 {
    color: var(--accent);
    margin-bottom: 0.75em;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.5em;
  }
  .speaking ul {
    list-style: none;
    padding: 0;
  }
  .speaking li {
    padding: 0.5em 1em;
    color: var(--text-secondary);
  }
  @media (max-width: 720px) {
    .recent-posts li a {
      flex-direction: column;
      gap: 0.15em;
    }
    .recent-posts .footprints {
      display: none;
    }
  }
</style>
