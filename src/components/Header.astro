---
import { Icon } from 'astro-icon/components';
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';

const thirtyTwo = 32;
---

<header>
  <nav>
    <h2><a href='/'>{SITE_TITLE}</a></h2>
    <div class='internal-links'>
      <HeaderLink href='/'>Home</HeaderLink>
      <HeaderLink href='/blog'>Blog</HeaderLink>
      <HeaderLink href='/archive'>Archive</HeaderLink>
      <HeaderLink href='/about'>About</HeaderLink>
    </div>
    <div class='social-links'>
      <a href='https://bsky.app/profile/edezekiel.bsky.social' target='_blank'>
        <span class='sr-only'>Follow me on Bluesky</span>
        <Icon
          name='simple-icons:bluesky'
          aria-hidden='true'
          width={thirtyTwo}
          height={thirtyTwo}
        />
      </a>
      <a href='https://github.com/edezekiel' target='_blank'>
        <span class='sr-only'>Go to my GitHub profile</span>
        <Icon
          name='mdi:github'
          aria-hidden='true'
          astro-icon='social/github'
          width={thirtyTwo}
          height={thirtyTwo}
        />
      </a>
      <a href='https://www.linkedin.com/in/edezekiel/' target='_blank'>
        <span class='sr-only'>Follow me on LinkedIn</span>
        <Icon
          name='mdi:linkedin'
          aria-hidden='true'
          astro-icon='social/linkedin'
          width={thirtyTwo}
          height={thirtyTwo}
        />
      </a>
      <HeaderLink href='/rss.xml'>
        <span class='sr-only'>Subscribe to my Feed</span>
        <Icon
          name='mdi:rss'
          aria-hidden='true'
          astro-icon='social/rss'
          width={thirtyTwo}
          height={thirtyTwo}
        /></HeaderLink
      >
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1.5em;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
    color: var(--accent);
    font-weight: 700;
    position: relative;
  }
  /* Hedgehog peeks out on site title hover */
  h2 a::after {
    content: '\1F994';
    display: inline-block;
    margin-left: 4px;
    font-size: 0.85em;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  h2 a:hover::after {
    opacity: 1;
    transform: translateX(0);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  nav a {
    padding: 1em 0.5em;
    color: var(--text-secondary);
    border-bottom: 3px solid transparent;
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  nav a:hover {
    color: var(--text-primary);
  }
  nav a.active {
    text-decoration: none;
    color: var(--accent-warm);
    border-bottom-color: var(--accent-warm);
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  .social-links a {
    color: var(--text-secondary);
    padding: 0.5em;
  }
  .social-links a:hover {
    color: var(--accent-light);
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
  }
</style>
