---
import { Icon } from 'astro-icon/components';
import HeaderLink from './HeaderLink.astro';

const today = new Date();
const thirtyTwo = 32;
---

<footer>
  &copy; {today.getFullYear()} Edward Ezekiel <span class='hedgehog-sep'>🦔</span> All rights reserved.
  <div class='social-links'>
    <a href='https://bsky.app/profile/edezekiel.bsky.social' target='_blank'>
      <span class='sr-only'>Follow me on Bluesky</span>
      <Icon
        name='simple-icons:bluesky'
        aria-hidden='true'
        width={thirtyTwo}
        height={thirtyTwo}
      />
    </a>
    <a href='https://github.com/edezekiel' target='_blank'>
      <span class='sr-only'>Go to my GitHub profile</span>
      <Icon
        name='mdi:github'
        aria-hidden='true'
        astro-icon='social/github'
        width={thirtyTwo}
        height={thirtyTwo}
      />
    </a>
    <a href='https://www.linkedin.com/in/edezekiel/' target='_blank'>
      <span class='sr-only'>Follow me on LinkedIn</span>
      <Icon
        name='mdi:linkedin'
        aria-hidden='true'
        astro-icon='social/linkedin'
        width={thirtyTwo}
        height={thirtyTwo}
      />
    </a>
		<HeaderLink href='/rss.xml'>
			<span class='sr-only'>Subscribe to my Feed</span>
			<Icon
				name='mdi:rss'
				aria-hidden='true'
				astro-icon='social/rss'
				width={thirtyTwo}
				height={thirtyTwo}
			/></HeaderLink
		>
  </div>
</footer>
<style>
  footer {
    padding: 2em 1em 4em 1em;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
    text-align: center;
    font-size: 0.9em;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1em;
    margin-top: 1em;
  }
  .social-links a {
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }
  .social-links a:hover {
    color: var(--accent-light);
  }
  .hedgehog-sep {
    font-size: 0.85em;
    opacity: 0.4;
    transition: opacity 0.3s ease;
    cursor: default;
  }
  .hedgehog-sep:hover {
    opacity: 1;
  }
</style>
